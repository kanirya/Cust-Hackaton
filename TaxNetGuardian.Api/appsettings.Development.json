{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Workers": {
    "QueueMode": "File",
    "ObjectStoreMode": "File",
    "LocalStackEndpoint": "http://localhost:4566",
    "ApiBaseUrl": "http://localhost:5191",
    "DataRoot": ".appdata/workers"
  },
  "TaxNet": {
    "Environment": "dev",
    "Auth": {
      "Mode": "DevelopmentHeaders",
      "RequireHttpsMetadata": false
    },
    "RateLimits": {
      "PermitLimit": 600,
      "WindowSeconds": 60,
      "QueueLimit": 100
    }
  }
}
